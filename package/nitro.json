{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "rnfoundationmodels"
  ],
  "ios": {
    "iosModuleName": "RNFoundationModels"
  },
  "android": {
    "androidNamespace": [
      "RNFoundationModels"
    ],
    "androidCxxLibName": "RNFoundationModels"
  },
  "autolinking": {
    "LanguageModelSessionFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridLanguageModelSessionFactory"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
