{
  "name": "react-native-foundation-models",
  "version": "0.1.0",
  "description": "A React Native Nitro module",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "./src/index.ts",
  "author": "Developer",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib",
    "build": "rm -rf lib && bun typecheck && bob build",
    "specs": "bunx nitrogen --logLevel=\"debug\"",
    "generate": "node lib/commonjs/cli.js",
    "generate:dev": "ts-node src/cli.ts",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "nitro"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/corasan/react-native-foundation-models.git"
  },
  "license": "MIT",
  "bugs": "https://github.com/corasan/react-native-foundation-models/issues",
  "homepage": "https://github.com/corasan/react-native-foundation-models#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src",
    "lib",
    "nitrogen",
    "cpp",
    "ios",
    "plugin",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "react-native.config.js",
    "android/build.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/src",
    "app.plugin.js",
    "*.podspec",
    "generable.config.example.ts",
    "bin",
    "README.md"
  ],
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.1",
    "nitrogen": "0.35.4",
    "react-native-builder-bob": "^0.40.13",
    "release-it": "^19.0.4",
    "ts-node": "^10.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.35.4"
  },
  "release-it": {
    "npm": {
      "publish": true,
      "skipVersion": true
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    },
    "hooks": {
      "after:bump": "bun specs",
      "before:release": "bun run build"
    },
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}",
      "requireCleanWorkingDir": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "conventionalcommits",
          "types": [
            {
              "type": "feat",
              "section": "✨ Features"
            },
            {
              "type": "fix",
              "section": "🐞 Fixes"
            },
            {
              "type": "chore(deps)",
              "section": "🛠️ Dependency Upgrades"
            },
            {
              "type": "perf",
              "section": "🏎️ Performance Improvements"
            },
            {
              "type": "docs",
              "section": "📚 Documentation"
            }
          ]
        }
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
